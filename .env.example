APP_ENV=local
APP_DEBUG=true
APP_BASE_URL=http://localhost:5173
APP_AUTO_STATUS_CHECK=true

# active environment: sandbox | production | custom
GOPAY_ACTIVE_ENV=sandbox

# Sandbox credentials
GOPAY_SANDBOX_GOID=8123456789
GOPAY_SANDBOX_CLIENT_ID=your_sandbox_client_id
GOPAY_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret
GOPAY_SANDBOX_GATEWAY_URL=https://gw.sandbox.gopay.com/api

# Production credentials - keep empty until you really need them
GOPAY_PRODUCTION_GOID=
GOPAY_PRODUCTION_CLIENT_ID=
GOPAY_PRODUCTION_CLIENT_SECRET=
GOPAY_PRODUCTION_GATEWAY_URL=https://gate.gopay.cz/api

# Defaults for generated payloads
GOPAY_DEFAULT_CURRENCY=CZK
GOPAY_DEFAULT_LANG=CS
GOPAY_DEFAULT_RETURN_URL=http://localhost:5173/?returned=1

# Localhost is not reachable by GoPay notifications.
# Use ngrok / Cloudflare Tunnel and set a public HTTPS URL for notification testing.
GOPAY_ENABLE_NOTIFICATION_URL=false
GOPAY_DEFAULT_NOTIFICATION_URL=

# Express
PORT=3001
SESSION_SECRET=change-me-local-only
CORS_ORIGIN=http://localhost:5173
